# {{ ansible_managed }}
services:
  postgres:
    image: {{ postgres_image }}
    container_name: postgres
    restart: unless-stopped
    # backfill_mode sizes Postgres for bulk ingest on the up-specced VM
    # (see RUNBOOK.md). synchronous_commit=off trades crash-safety of the
    # last few seconds for ingest speed — acceptable only during backfill.
    command:
      - postgres
      - "-c"
      - "shared_buffers={{ '2GB' if backfill_mode else '256MB' }}"
      - "-c"
      - "max_wal_size={{ '4GB' if backfill_mode else '1GB' }}"
{% if backfill_mode %}
      - "-c"
      - "synchronous_commit=off"
{% endif %}
    environment:
      # Superuser stays 'postgres' and is only used for admin/backups.
      # Services connect as least-privilege roles created by init-db.sql.
      POSTGRES_PASSWORD: "{{ postgres_superuser_password }}"
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=C"
    volumes:
      - ./postgres-data:/var/lib/postgresql/data
      - ./init-db.sql:/docker-entrypoint-initdb.d/init-db.sql
    networks:
      - matrix
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  synapse:
    image: {{ synapse_image }}
    container_name: synapse
    restart: unless-stopped
    environment:
      SYNAPSE_CONFIG_PATH: /data/homeserver.yaml
      SYNAPSE_CACHE_FACTOR: "{{ '2.0' if backfill_mode else '0.5' }}"
    volumes:
      - ./synapse-data:/data
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - matrix

  caddy:
    image: {{ caddy_image }}
    container_name: caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "8448:8448"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile
      - ./caddy-data:/data
      - ./caddy-config:/config
      - ./element-web:/srv/element:ro
    networks:
      - matrix

  mautrix-discord:
    image: {{ discord_image }}
    container_name: mautrix-discord
    restart: unless-stopped
    volumes:
      - ./discord-data:/data
    depends_on:
      - synapse
    networks:
      - matrix

networks:
  matrix:
    driver: bridge
